# Copy this file to .env and fill in real values for local development.
# .env is git-ignored - never commit real secrets.
# Whenever a new env var is added to cronhub/core/config.py, add it here too.

# --- Admin login (used when Keycloak is disabled) ---
CRONHUB_ADMIN_USER=admin
CRONHUB_ADMIN_PASS=change-me

# --- Session signing ---
CRONHUB_SECRET_KEY=change-me

# --- Keycloak / OIDC ---
KEYCLOAK_ENABLED=true
KEYCLOAK_BASE_URL=https://auth.msolution.az
KEYCLOAK_REALM=MSolution
KEYCLOAK_CLIENT_ID=cronhub
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_SCOPES=openid profile email

# CronHub public URL (used for the OIDC callback)
APP_BASE_URL=https://cronhub.msolution.az

# --- RBAC / Users / Export / Audit retention ---
CRONHUB_AUDIT_RETENTION_DAYS=30
CRONHUB_READONLY_GROUPS=CronHubReadOnly
CRONHUB_WRITE_GROUPS=DevOps,BA

CRONHUB_EXPORT_DIR=/data/exports
CRONHUB_EXPORT_SECRET=

CRONHUB_USERS_DB_FILE=data/jobs.sqlite

# --- Default psql connection for shell jobs (optional) ---
# psql reads these automatically via libpq, so shell job commands only need
# to pass -h/-d (host/database differ per job) and can drop -p/-U/password:
#   psql -h <host> -d <database> -c "SELECT ..."
PGPORT=5432
PGUSER=your-db-user
PGPASSWORD=
